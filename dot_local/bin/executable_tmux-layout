#!/bin/sh
set -eu

usage() {
    cat <<'EOF'
Usage: tmux-layout [SESSION_NAME] [WORKDIR]

Create or attach to a tmux session with this layout:
  - pane 1: top pane
  - pane 2: bottom pane, 5 lines tall

Defaults:
  SESSION_NAME: dev
  WORKDIR:      current directory

Optional environment variables:
  TMUX_LAYOUT_WINDOW_NAME  Rename the first window (default: main)
  TMUX_LAYOUT_PANE1_CMD    Command to run in the top pane
  TMUX_LAYOUT_PANE2_CMD    Command to run in the bottom pane
  TMUX_LAYOUT_NO_ATTACH    Set to 1 to create the session without attaching
  TMUX_SOCKET_NAME         tmux socket name, useful for testing
EOF
}

tmux_cmd() {
    if [ -n "${TMUX_SOCKET_NAME:-}" ]; then
        tmux -L "$TMUX_SOCKET_NAME" "$@"
        return
    fi

    tmux "$@"
}

run_pane_command() {
    pane_id=$1
    pane_cmd=$2

    if [ -n "$pane_cmd" ]; then
        tmux_cmd send-keys -t "$pane_id" "$pane_cmd" C-m
    fi
}

current_window_size() {
    if [ -n "${TMUX:-}" ]; then
        tmux_cmd display-message -p '#{window_width} #{window_height}' 2>/dev/null
        return
    fi

    if ! command -v tput >/dev/null 2>&1; then
        return 1
    fi

    cols=$(tput cols 2>/dev/null) || return 1
    lines=$(tput lines 2>/dev/null) || return 1

    case "$cols" in
        ''|*[!0-9]*) return 1 ;;
    esac

    case "$lines" in
        ''|*[!0-9]*) return 1 ;;
    esac

    if [ "$cols" -le 0 ] || [ "$lines" -le 1 ]; then
        return 1
    fi

    # tmux window height excludes the status line.
    printf '%s %s\n' "$cols" "$((lines - 1))"
}

attach_or_switch() {
    if [ "${TMUX_LAYOUT_NO_ATTACH:-0}" = "1" ]; then
        return
    fi

    if [ -n "${TMUX:-}" ]; then
        tmux_cmd switch-client -t "$session_name"
    else
        tmux_cmd attach-session -t "$session_name"
    fi
}

case "${1:-}" in
    -h|--help)
        usage
        exit 0
        ;;
esac

if [ "$#" -gt 2 ]; then
    usage >&2
    exit 1
fi

if ! command -v tmux >/dev/null 2>&1; then
    printf '%s\n' 'tmux-layout: tmux is not installed or not in PATH' >&2
    exit 127
fi

session_name=${1:-dev}
workdir=${2:-$PWD}
window_name=${TMUX_LAYOUT_WINDOW_NAME:-main}
pane1_cmd=${TMUX_LAYOUT_PANE1_CMD:-}
pane2_cmd=${TMUX_LAYOUT_PANE2_CMD:-}

if [ ! -d "$workdir" ]; then
    printf 'tmux-layout: workdir does not exist: %s\n' "$workdir" >&2
    exit 1
fi

if tmux_cmd has-session -t "$session_name" 2>/dev/null; then
    attach_or_switch
    exit 0
fi

if window_size=$(current_window_size); then
    window_width=${window_size% *}
    window_height=${window_size#* }
    tmux_cmd new-session -d -x "$window_width" -y "$window_height" -s "$session_name" -n "$window_name" -c "$workdir"
else
    tmux_cmd new-session -d -s "$session_name" -n "$window_name" -c "$workdir"
fi

top_pane=$(tmux_cmd display-message -p -t "$session_name:$window_name" '#{pane_id}')
bottom_pane=$(tmux_cmd split-window -v -l 7 -t "$top_pane" -c "$workdir" -P -F '#{pane_id}')

run_pane_command "$top_pane" "$pane1_cmd"
run_pane_command "$bottom_pane" "$pane2_cmd"

tmux_cmd select-pane -t "$top_pane"

attach_or_switch
